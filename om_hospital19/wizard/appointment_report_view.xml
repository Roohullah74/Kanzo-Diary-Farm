<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_appointment_form" model="ir.ui.view">
        <field name="name">report.appointment.wizard.form</field>
        <field name="model">appointment.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Appointment Report">
                <group>
                    <group>
                        <field name="patient_id1"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report"
                            type="object"
                            string="Print"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_report_appointment_pdf" model="ir.actions.act_window">
        <field name="name">Appointment Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">appointment.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_report_appointment_form"/>
        <field name="target">new</field>
    </record>
</odoo>


