<odoo>
    <record id="view_hr_payslip_form_inherit_custom" model="ir.ui.view">
    <field name="name">hr.payslip.form.inherit.custom</field>
    <field name="model">hr.payslip</field>
    <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
    <field name="arch" type="xml">

        <!-- Add button inside header -->
        <xpath expr="//header" position="inside">
            <button name="action_salary_letter"
                    type="object"
                    string="Salary Letter"
                    class="btn-primary"/>
        </xpath>

    </field>
</record>
</odoo>
