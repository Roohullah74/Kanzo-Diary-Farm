<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Server Action -->
    <record id="action_confirm_appointments" model="ir.actions.server">
        <field name="name">Confirm Appointment</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="om_hospital19.model_hospital_appointment"/>
        <field name="binding_model_id" ref="om_hospital19.model_hospital_appointment"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">records.action_confirm()</field>
        <!--         <field name="code">-->
        <!--                if records:-->
        <!--                    action = records.action_l10n_id_update_payment_status()-->
        <!--            </field>-->
    </record>


    <!-- List View -->
    <record id="view_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <!--                mlti_edit='1' it mean that  you edite the each row then this row select  many record then edit one roohullah 5 record update-->
                <header>
                    <button name="action_done"
                            string="Done state"
                            class="btn-primary"
                            type="object"/>
                </header>
                <field name="name"/>
                <field name="doctor_id"/>
                <field name="patient_id"/>
                <field name="age" optional="show"/>
                <field name="gender" optional="show"/>
                <!--option ='show', and  optional =hide the right side will be present of it show-->
                <field name="date_appointment" optional="show"/>
                <field name="date_checkup" optional="hide"/>
                <field name="note" optional="show"/>
                <field name="state" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button id="button_confirm" name="action_confirm"
                            string="Confirm" class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Are you sure that you need to confirm ?"
                            type="object"/>
                    <button id="button_done" name="action_done"
                            string="Mark As Done" class="btn-primary"
                            invisible="state != 'confirm'"
                            type="object"/>
                    <button id="button_draft" name="action_draft"
                            string="Set To Draft" class="btn-primary"
                            invisible="state != 'cancel'"
                            type="object"/>
                    <button id="button_cancel" name="action_cancel"
                            string="Cancel"
                            invisible="state not in ['draft', 'done', 'confirm']"
                            confirm="Are you sure that you need to cancel ?"
                            type="object"/>
                    <button name="action_url_lindin" string="Developer likdin"
                            class="btn-primary" type="object"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirm,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <!--                            the readonly=1 add the record then it not show then if add force_save=1 then show it-->
                            <field name="gender" readonly="1" force_save="1"/>
                            <field name="age"/>
                            <field name="note"/>

                        </group>
                        <group>
                            <field name="doctor_id" options="{'no_edit': True, 'no_create': True, 'no_open': True}"/>
                            <field name="date_appointment"/>
                            <field name="date_checkup"/>
                        </group>
                    </group>
                    <!--                    this one the buttom of the record which are present the date  many page will be present of it-->
                    <notebook>
                        <page string="Doctor Prescription" name="doctor_prescription">
                            <group>
                                <field name="prescription"/>
                            </group>
                        </page>
                        <page string="Medicine" name="medicine">
                            <field name="prescription_line_ids">
                                <!--editable='top' or editable='bottom'-->
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="qty"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                        </group>
                                        <group>
                                            <field name="qty"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Other Info" name="other_info">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

