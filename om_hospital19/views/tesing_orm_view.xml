<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_test_patient_tree" model="ir.ui.view">
        <field name="name">test.patient.tree</field>
        <field name="model">test.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name1"/>
                <field name="age1"/>
            </list>
        </field>
    </record>
kkkkkkkkkkkkkkkkk
    kkkkkkkkkkkkkkkkk

    <!-- Form View -->
    <record id="view_test_patient_form" model="ir.ui.view">
        <field name="name">test.patient.form</field>
        <field name="model">test.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code_num" placeholder="Enteri code"/>
                        <field name="name1"/>
                        <field name="age1"/>
                    </group>

                    <button
                        name="create_test_patient"
                        string="Create Ahmed"
                        type="object"
                        class="btn-primary"/>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_test_patient" model="ir.actions.act_window">
        <field name="name">Test Patients</field>
        <field name="res_model">test.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_test_root"
              name="Test ORM"
              parent="menu_hospital_root"/>
    <menuitem id="menu_test_patient"
              name="Test"
              action="action_test_patient"
              parent="menu_test_root"/>
</odoo>