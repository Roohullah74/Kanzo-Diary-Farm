<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Category -->
        <record id="module_category_hospital" model="ir.module.category">
            <field name="name">Hospital Management</field>
            <field name="sequence">20</field>
        </record>

        <!-- Level 1: User -->
        <record id="group_custom_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_hospital"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Level 2: Assistant Manager -->
        <record id="group_custom_assistant_manager" model="res.groups">
            <field name="name">Assistant Manager</field>
            <field name="category_id" ref="module_category_hospital"/>
            <field name="implied_ids" eval="[(4, ref('om_hospital19.group_custom_user'))]"/>
        </record>

        <!-- Level 3: Manager -->
        <record id="group_custom_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_hospital"/>
            <field name="implied_ids" eval="[(4, ref('om_hospital19.group_custom_assistant_manager'))]"/>
        </record>

    </data>
</odoo>











