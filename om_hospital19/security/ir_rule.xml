<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- USER: sees ONLY own patients -->
        <record id="rule_patient_user" model="ir.rule">
            <field name="name">Patient: User sees own only</field>
            <field name="model_id" ref="om_hospital19.model_hospital_patient"/>
            <field name="groups" eval="[(4, ref('om_hospital19.group_custom_user'))]"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- USER: sees ONLY own appointments -->
        <record id="rule_appointment_user" model="ir.rule">
            <field name="name">Appointment: User sees own only</field>
            <field name="model_id" ref="om_hospital19.model_hospital_appointment"/>
            <field name="groups" eval="[(4, ref('om_hospital19.group_custom_user'))]"/>
            <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ASSISTANT MANAGER: Read Only, sees ALL records -->
        <record id="rule_patient_assistant" model="ir.rule">
            <field name="name">Patient: Assistant sees all</field>
            <field name="model_id" ref="om_hospital19.model_hospital_patient"/>
            <field name="groups" eval="[(4, ref('om_hospital19.group_custom_assistant_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- MANAGER: sees ALL records + full control -->
        <record id="rule_patient_manager" model="ir.rule">
            <field name="name">Patient: Manager full access</field>
            <field name="model_id" ref="om_hospital19.model_hospital_patient"/>
            <field name="groups" eval="[(4, ref('om_hospital19.group_custom_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>


